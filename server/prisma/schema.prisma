generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  passwordHash String
  name         String
  role         Role         @default(agent)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  claims       Claim[]
  commissions  Commission[]
  customers    Customer[]
  dealers      Dealer[]
  followUps    FollowUp[]
  leads        Lead[]
  payments     Payment[]
  policies     Policy[]

  @@index([email])
}

model Dealer {
  id          String       @id @default(uuid())
  userId      String
  name        String
  phone       String?
  address     String?
  createdBy   String
  updatedBy   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?
  commissions Commission[]
  user        User         @relation(fields: [userId], references: [id])
  policies    Policy[]

  @@index([userId])
  @@index([name])
}

model Lead {
  id                String              @id @default(uuid())
  userId            String
  name              String
  phone             String?
  interestedProduct String?
  status            LeadStatus          @default(new)
  nextFollowUpDate  DateTime?
  notes             String?
  createdBy         String
  updatedBy         String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  companyId         String?
  expiryDate        DateTime?
  idv               Float?
  make              String?
  model             String?
  od                Float?
  policyType        PolicyType?
  premiumAmount     Float?
  startDate         DateTime?
  tax               Float?
  totalPremium      Float?
  tp                Float?
  vehicleClass      PolicyVehicleClass?
  vehicleNumber     String?
  dealerId          String?
  registrationDate  DateTime?
  ncbPercentage     Float?
  policyOrigin      PolicyOrigin?
  user              User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([phone])
  @@index([createdAt])
  @@index([status])
}

model Customer {
  id        String     @id @default(uuid())
  userId    String
  name      String
  phone     String?
  email     String?
  address   String?
  createdBy String
  updatedBy String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?
  dob       DateTime?
  claims    Claim[]
  user      User       @relation(fields: [userId], references: [id])
  followUps FollowUp[]
  payments  Payment[]
  policies  Policy[]

  @@index([userId])
  @@index([phone])
  @@index([createdAt])
}

model Company {
  id          String       @id @default(uuid())
  name        String
  type        String?
  category    String?
  commissions Commission[]
  policies    Policy[]

  @@index([name])
}

model Policy {
  id                 String              @id @default(uuid())
  userId             String
  customerId         String
  companyId          String
  policyNumber       String?
  policyType         PolicyType
  vehicleNumber      String?
  startDate          DateTime
  expiryDate         DateTime
  sumInsured         Float?
  premiumAmount      Float
  premiumMode        PremiumMode         @default(yearly)
  productName        String?
  noOfYears          Int                 @default(1)
  status             PolicyStatus        @default(active)
  parentPolicyId     String?
  createdBy          String
  updatedBy          String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  deletedAt          DateTime?
  dealerId           String?
  idv                Float?
  make               String?
  model              String?
  od                 Float?
  paymentMethod      String?
  tax                Float?
  totalPremium       Float?
  tp                 Float?
  vehicleClass       PolicyVehicleClass?
  cancelledAt        DateTime?
  registrationDate   DateTime?
  ncbPercentage      Float?
  policyOrigin       PolicyOrigin        @default(fresh)
  claims             Claim[]
  commissionPolicies CommissionPolicy[]
  followUps          FollowUp[]
  payments           Payment[]
  company            Company             @relation(fields: [companyId], references: [id])
  customer           Customer            @relation(fields: [customerId], references: [id])
  dealer             Dealer?             @relation(fields: [dealerId], references: [id])
  parentPolicy       Policy?             @relation("PolicyRenewal", fields: [parentPolicyId], references: [id])
  renewals           Policy[]            @relation("PolicyRenewal")
  user               User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([customerId])
  @@index([companyId])
  @@index([expiryDate])
  @@index([createdAt])
  @@index([status])
}

model Claim {
  id          String   @id @default(uuid())
  userId      String
  policyId    String
  customerId  String
  claimNumber String?
  claimAmount Float
  claimDate   DateTime
  status      String   @default("filed")
  reason      String?
  createdBy   String
  createdAt   DateTime @default(now())
  customer    Customer @relation(fields: [customerId], references: [id])
  policy      Policy   @relation(fields: [policyId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([policyId])
  @@index([customerId])
  @@index([createdAt])
}

model Payment {
  id         String        @id @default(uuid())
  userId     String
  policyId   String
  customerId String
  amount     Float
  dueDate    DateTime
  paidDate   DateTime?
  paidAmount Float?
  status     PaymentStatus @default(pending)
  notes      String?
  createdBy  String
  createdAt  DateTime      @default(now())
  customer   Customer      @relation(fields: [customerId], references: [id])
  policy     Policy        @relation(fields: [policyId], references: [id])
  user       User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([policyId])
  @@index([customerId])
  @@index([dueDate])
  @@index([status])
  @@index([createdAt])
}

model FollowUp {
  id               String         @id @default(uuid())
  userId           String
  customerId       String
  policyId         String?
  nextFollowUpDate DateTime
  notes            String?
  status           FollowUpStatus @default(pending)
  createdBy        String
  createdAt        DateTime       @default(now())
  customer         Customer       @relation(fields: [customerId], references: [id])
  policy           Policy?        @relation(fields: [policyId], references: [id])
  user             User           @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([customerId])
  @@index([nextFollowUpDate])
  @@index([status])
  @@index([createdAt])
}

model Commission {
  id                 String             @id @default(uuid())
  userId             String
  dealerId           String
  companyId          String?
  periodStart        DateTime
  periodEnd          DateTime
  odPercentage       Float
  tpPercentage       Float
  totalOdCommission  Float              @default(0)
  totalTpCommission  Float              @default(0)
  totalCommission    Float              @default(0)
  totalPremium       Float              @default(0)
  notes              String?
  status             String             @default("draft")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  company            Company?           @relation(fields: [companyId], references: [id])
  dealer             Dealer             @relation(fields: [dealerId], references: [id])
  user               User               @relation(fields: [userId], references: [id])
  commissionPolicies CommissionPolicy[]

  @@index([userId])
  @@index([dealerId])
  @@index([companyId])
  @@index([createdAt])
}

model CommissionPolicy {
  id            String     @id @default(uuid())
  commissionId  String
  policyId      String
  vehicleNumber String?
  make          String?
  model         String?
  vehicleClass  String?
  od            Float      @default(0)
  tp            Float      @default(0)
  premiumAmount Float      @default(0)
  startDate     DateTime
  expiryDate    DateTime
  odCommission  Float      @default(0)
  tpCommission  Float      @default(0)
  commission    Commission @relation(fields: [commissionId], references: [id], onDelete: Cascade)
  policy        Policy     @relation(fields: [policyId], references: [id])

  @@index([commissionId])
  @@index([policyId])
}

enum Role {
  agent
  staff
}

enum LeadStatus {
  new
  contacted
  interested
  converted
  lost
}

enum PolicyStatus {
  active
  expired
  cancelled
}

enum PaymentStatus {
  pending
  paid
  partial
  overdue
}

enum FollowUpStatus {
  pending
  completed
  cancelled
}

enum PremiumMode {
  monthly
  quarterly
  halfYearly
  yearly
  single
}

enum PolicyType {
  motor
  health
  life
  other
}

enum PolicyVehicleClass {
  TW
  PCV
  PVT
  GCV
  Misc_D
  CPM
  Fire
  Public_Liability
  SAOD_TW
  SAOD_PVT
  CPA
  Others
}

enum PolicyOrigin {
  fresh
  external_renewal
  in_system_renewal
}
