{
  "name": "insurance-crm",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "install:all": "cd server && npm install && cd ../client && npm install",
    "postinstall": "npm run db:generate",
    "db:generate": "npx prisma generate --schema=./server/prisma/schema.prisma",
    "db:migrate": "npx prisma migrate dev --schema=./server/prisma/schema.prisma --name auto_sync",
    "db:migrate:name": "npx prisma migrate dev --schema=./server/prisma/schema.prisma",
    "db:reset": "npx prisma migrate reset --schema=./server/prisma/schema.prisma --force",
    "db:deploy": "npx prisma migrate deploy --schema=./server/prisma/schema.prisma",
    "db:seed": "npx prisma db seed --schema=./server/prisma/schema.prisma",
    "db:setup": "npm run db:migrate && npm run db:seed"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}